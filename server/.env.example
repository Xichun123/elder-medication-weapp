# 服务
PORT=8787
HOST=0.0.0.0
NODE_ENV=production

# 登录与数据库
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN_SEC=604800
WX_APP_ID=
WX_APP_SECRET=
ALLOW_DEV_LOGIN=0
DATABASE_PATH=./data/app.db
PUBLIC_BASE_URL=https://api.example.com

# 文本 AI：OpenAI Chat Completions 兼容接口
AI_API_URL=
AI_API_KEY=
AI_MODEL=
AI_UPSTREAM_TIMEOUT_MS=12000
AI_REQUEST_TIMEOUT_MS=25000
AI_ACTION_TTL_MS=300000

# 语音识别：openai_multipart 或 dashscope_async；密钥留空时复用 AI_API_KEY
STT_PROVIDER=dashscope_async
STT_API_URL=
STT_API_KEY=
STT_MODEL=
STT_UPSTREAM_TIMEOUT_MS=15000

# 语音合成：与文本模型独立配置
TTS_API_URL=
TTS_API_KEY=
TTS_MODEL=
TTS_VOICE=
# 方言/音色映射，逗号分隔：tone:upstreamVoice
# 例：female_warm:longxiaochun,male:longshu,dialect_dongbei:longlaotie,dialect_sichuan:longlaotie,dialect_cantonese:longyingmu,dialect_henan:longlaotie
TTS_VOICE_MAP=
TTS_UPSTREAM_TIMEOUT_MS=15000

# 隐私提示：AI 问答、个性化陪伴短句和语音会把所需的老人/家属称呼、用药、
# 过敏史、症状、对话和录音发送给上述第三方服务。上线前必须在小程序隐私说明中披露用途、范围和供应商。
