# 服务
PORT=8787
HOST=0.0.0.0
NODE_ENV=production

# JWT（请换成足够长的随机串）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN_SEC=604800

# 微信小程序（生产必填；仅服务端保存）
WX_APP_ID=
WX_APP_SECRET=

# 开发免微信：设置后 POST /auth/wx-login 可用 { "devOpenid": "dev-user-1" }
# 生产环境务必留空
ALLOW_DEV_LOGIN=0

# 需 Node.js 22.5+（使用内置 node:sqlite）
# SQLite 文件路径（相对 server 目录或绝对路径）
DATABASE_PATH=./data/app.db

# AI 拍药盒识别（通用 OpenAI Chat Completions 多模态接口）
# 以下示例继续使用 GitHub Models；PAT 仅需 models:read 权限并且只能保存在服务端
RECOGNITION_API_URL=https://models.github.ai/inference/chat/completions
RECOGNITION_API_KEY=
RECOGNITION_MODEL=openai/gpt-4.1-mini
RECOGNITION_TIMEOUT_MS=30000
