.dict-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:10rpx; margin-top:24rpx; }.dict-stats .metric { padding:18rpx 6rpx; text-align:center; }.dict-stats .metric-number { font-size:36rpx; color:var(--primary); }.dict-card { margin-bottom:18rpx; }.dict-row { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; padding:14rpx 0; border-bottom:1rpx solid var(--border); }.dict-code { color:var(--primary); font-family:monospace; font-size:23rpx; }.dict-source { margin-top:18rpx; color:var(--light); font-size:21rpx; }
