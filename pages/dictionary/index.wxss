.dict-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:12rpx; margin-top:26rpx; }
.dict-stats .metric { padding:20rpx 6rpx; text-align:center; }
.dict-stats .metric-number { font-size:38rpx; color:var(--primary); }
.dict-card { margin-bottom:18rpx; }
.dict-row { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; padding:16rpx 0; border-bottom:1rpx solid var(--border); font-size:26rpx; }
.dict-code { color:var(--primary); font-family:monospace; font-size: 26rpx; }
.dict-source { margin-top:20rpx; color:var(--light); font-size: 26rpx; }
