.relation-notice { margin-top: 22rpx; }
.relation-line { display: grid; grid-template-columns: minmax(0,1fr) auto minmax(0,1fr); gap: 16rpx; align-items: center; }
.relation-line .right { text-align: right; }
.arrow { color: var(--light); font-size: 40rpx; }
.relation-tags { margin-top: 18rpx; }
.member-avatar-img { width: 100%; height: 100%; display: block; border-radius: 50%; }
.member-avatar-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--primary); background: var(--primary-soft); font-size: 32rpx; font-weight: 700; }
