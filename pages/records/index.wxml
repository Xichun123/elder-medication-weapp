<view class="page">
  <view wx:if="{{!editing}}">
    <view class="row between gap"><view><text class="page-title">用药记录</text><text class="page-subtitle">老人 × 药物 × 剂量频次</text></view><button wx:if="{{canEdit}}" class="btn primary small" bindtap="add">＋ 新增</button></view>
    <view class="filter-bar"><picker range="{{elderOptions}}" range-key="name" value="{{elderIndex}}" bindchange="onElderChange"><view class="filter">{{elderOptions[elderIndex].name}} ▾</view></picker><input class="search flex-1" value="{{keyword}}" placeholder="搜索药物名" bindinput="onKeyword"/></view>
    <view wx:for="{{filteredList}}" wx:key="record_id" class="list-card"><view class="row between gap"><view class="flex-1"><text class="list-title">{{item.drug_name}}</text><view class="list-subtitle">{{item.elder_name}} · {{item.dose}} · {{item.frequency}}</view></view><text class="tag primary">{{item.drug_category_label}}</text></view><view class="list-meta">{{item.start_date}} 至 {{item.end_date || '长期'}}</view><view wx:if="{{canEdit}}" class="actions split-actions"><button class="btn small" data-id="{{item.record_id}}" bindtap="edit">编辑</button><button class="btn danger small" data-id="{{item.record_id}}" bindtap="remove">删除</button></view></view>
    <view wx:if="{{!loading && !filteredList.length}}" class="card empty"><image class="empty-icon" src="/assets/icons/line-empty-box.png" mode="aspectFit" aria-role="img" aria-label="空状态"/>暂无用药记录</view><view wx:if="{{loading}}" class="loading" aria-role="status">正在加载…</view>
  </view>
  <view wx:else><text class="page-title">编辑用药记录</text><view class="card form-card"><view class="notice">{{form.elder_name}} · {{form.drug_name}}</view><view class="field"><text class="field-label required">剂量</text><input class="input" value="{{form.dose}}" data-field="dose" bindinput="onInput"/></view><view class="field"><text class="field-label">频次</text><view class="radio-row"><view wx:for="{{frequencyOptions}}" wx:key="*this" class="choice {{form.frequency === item ? 'active' : ''}}" data-value="{{item}}" bindtap="chooseFrequency" hover-class="pressable-hover">{{item}}</view></view></view><view class="field"><text class="field-label">开始日期</text><picker mode="date" value="{{form.start_date}}" bindchange="onStartDate"><view class="picker">{{form.start_date}} ▾</view></picker></view><view class="field"><text class="field-label">结束日期</text><view class="row gap"><picker class="flex-1" mode="date" value="{{form.end_date || form.start_date}}" bindchange="onEndDate"><view class="picker">{{form.end_date || '长期 / 点击选择'}} ▾</view></picker><button wx:if="{{form.end_date}}" class="btn small" bindtap="clearEndDate">清空</button></view></view><view class="form-actions"><button class="btn" bindtap="cancel">取消</button><button class="btn primary" loading="{{saving}}" bindtap="save">保存</button></view></view></view>
</view>
