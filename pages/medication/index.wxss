.loading.mini { padding: 18rpx; }
.match-list { margin: -8rpx 0 26rpx; border: 1rpx solid var(--border); border-radius: 18rpx; overflow: hidden; }
.match-item { padding: 22rpx; background: #FBFDFC; border-bottom: 1rpx solid var(--border); }
.match-item:last-child { border-bottom: 0; }
.contra { color: var(--danger); font-size: 26rpx; margin-top: 10rpx; }
.selected { padding: 22rpx; margin-bottom: 26rpx; border-radius: 18rpx; background: var(--primary-soft); }

.scan-card { margin-top: 24rpx; padding: 30rpx; overflow: hidden; color: #1E3A28; border: 1rpx solid #C9E8CF; border-radius: 28rpx; background: linear-gradient(145deg,#F0F9EE,#DCF1DE); box-shadow: 0 12rpx 28rpx rgba(46,139,74,.12); }
.scan-top { display: flex; align-items: center; gap: 22rpx; }
.scan-icon { width: 88rpx; height: 88rpx; flex: none; }
.scan-copy { flex: 1; min-width: 0; }
.scan-eyebrow { color: var(--primary); font-size: 26rpx; font-weight: 700; letter-spacing: 2rpx; }
.scan-title { margin-top: 4rpx; font-size: 36rpx; font-weight: 750; }
.scan-subtitle { margin-top: 6rpx; color: #4E6B55; font-size: 26rpx; line-height: 1.5; }
.scan-button { width: 100%; min-height: 96rpx; margin-top: 26rpx; padding: 0 24rpx; color: #fff; border-radius: 20rpx; background: var(--primary); font-size: 32rpx; font-weight: 650; line-height: 1.2; }
.scan-button[disabled] { opacity: .65; }
.scan-footnote { margin-top: 16rpx; color: #6B8471; font-size: 26rpx; line-height: 1.55; text-align: center; }

.recognition-card { margin-top: 20rpx; overflow: hidden; border: 1rpx solid var(--border); border-radius: 26rpx; background: #fff; box-shadow: 0 8rpx 22rpx rgba(24,48,43,.06); }
.recognition-photo { width: 100%; height: 260rpx; display: block; background: var(--soft); }
.recognition-content { padding: 28rpx; }
.recognition-kicker { color: var(--primary); font-size: 26rpx; font-weight: 700; letter-spacing: 2rpx; }
.recognition-heading { margin-top: 4rpx; font-size: 32rpx; font-weight: 700; }
.review-badge { flex: none; padding: 6rpx 16rpx; color: var(--warning); border-radius: 999rpx; background: var(--warning-soft); font-size: 26rpx; }
.review-badge.confirmed { color: var(--primary); background: var(--primary-soft); }
.recognition-loading { display: flex; align-items: center; gap: 12rpx; margin-top: 24rpx; padding: 20rpx; color: var(--muted); border-radius: 16rpx; background: #F4FAF7; font-size: 26rpx; }
.recognition-dot { width: 16rpx; height: 16rpx; flex: none; border-radius: 50%; background: var(--primary); box-shadow: 0 0 0 8rpx var(--primary-soft); animation: recpulse 1.2s infinite ease-in-out; }
@keyframes recpulse { 0%,100% { opacity: .4; } 50% { opacity: 1; } }
.recognition-grid { margin-top: 24rpx; border-top: 1rpx solid var(--border); }
.recognition-row { display: grid; grid-template-columns: 140rpx minmax(0,1fr); gap: 12rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--border); }
.recognition-label { color: var(--muted); font-size: 26rpx; }
.recognition-value { min-width: 0; color: var(--text); font-size: 27rpx; font-weight: 600; word-break: break-all; }
.visible-text { margin-top: 18rpx; padding: 18rpx; color: var(--muted); border-radius: 16rpx; background: #F4FAF7; font-size: 26rpx; }
.recognition-warning { margin-top: 14rpx; color: var(--danger); font-size: 26rpx; }
.uncertain { margin-top: 14rpx; color: var(--warning); font-size: 26rpx; }
.recognition-actions { display: flex; align-items: center; gap: 20rpx; margin-top: 24rpx; }
.text-button { min-height: 88rpx; padding: 0 8rpx; color: var(--muted); background: transparent; font-size: 29rpx; font-weight: 600; line-height: 1.2; }
.manual-heading { display: flex; align-items: center; justify-content: space-between; margin-bottom: 26rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid var(--border); font-size: 30rpx; font-weight: 700; }
.manual-tag { padding: 6rpx 16rpx; color: var(--primary); border-radius: 999rpx; background: var(--primary-soft); font-size: 26rpx; font-weight: 600; }
.create-drug-hint { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin: -4rpx 0 26rpx; padding: 20rpx; border: 1rpx dashed #ABD8B4; border-radius: 18rpx; background: #F0F9EE; }
.create-drug-copy { flex: 1; color: #4E6B55; font-size: 26rpx; line-height: 1.5; }
.review-confirmation { margin-bottom: 26rpx; padding: 22rpx; border: 1rpx solid #E3CDA3; border-radius: 18rpx; background: var(--warning-soft); }
.review-confirmation.confirmed { border-color: #ABD8B4; background: var(--primary-soft); }
.review-confirmation-title { margin-bottom: 16rpx; color: var(--warning); font-size: 27rpx; font-weight: 700; }
.review-confirmation.confirmed .review-confirmation-title { color: var(--primary); }
.review-confirmation-check { display: flex; align-items: flex-start; gap: 14rpx; color: var(--text); font-size: 26rpx; line-height: 1.55; }
.review-confirmation-check checkbox { flex: none; margin-top: 4rpx; }
.review-confirmation-note { margin-top: 12rpx; color: var(--muted); font-size: 26rpx; }
.package-image-save { display: flex; align-items: center; gap: 18rpx; margin-bottom: 26rpx; padding: 22rpx; border: 1rpx solid #ABD8B4; border-radius: 18rpx; background: #F0F9EE; }
.package-image-save-copy { flex: 1; min-width: 0; }
.package-image-save-title { color: var(--primary); font-size: 27rpx; font-weight: 700; }
.package-image-save-note { margin-top: 6rpx; color: #4E6B55; font-size: 26rpx; line-height: 1.5; }

.mask { position: fixed; z-index: 30; inset: 0; display: flex; align-items: center; padding: 34rpx; background: rgba(24,48,43,.48); }
.result-card { width: 100%; max-height: 80vh; overflow-y: auto; padding: 34rpx; border-radius: 28rpx; background: #fff; }
.result-head { display: flex; align-items: center; gap: 16rpx; }
.result-check { width: 56rpx; height: 56rpx; }
.result-title { font-size: 40rpx; font-weight: 700; }
.result-item { display: flex; align-items: flex-start; gap: 14rpx; padding: 22rpx 0; border-bottom: 1rpx solid var(--border); }
.result-text { flex: 1; font-size: 26rpx; }
