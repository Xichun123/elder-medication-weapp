.loading.mini { padding: 16rpx; }.match-list { margin: -8rpx 0 24rpx; border: 1rpx solid var(--border); border-radius: 16rpx; overflow: hidden; }.match-item { padding: 20rpx; background: #fdfaf6; border-bottom: 1rpx solid var(--border); }.match-item:last-child { border-bottom: 0; }.contra { color: var(--danger); font-size: 22rpx; margin-top: 8rpx; }.selected { padding: 20rpx; margin-bottom: 24rpx; border-radius: 16rpx; background: var(--primary-soft); }.mask { position: fixed; z-index: 30; inset: 0; display: flex; align-items: center; padding: 34rpx; background: rgba(61,46,31,.48); }.result-card { width: 100%; max-height: 80vh; overflow-y: auto; padding: 32rpx; border-radius: 26rpx; background: #fff; }.result-item { display: flex; align-items: flex-start; gap: 14rpx; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }.result-text { flex: 1; font-size: 25rpx; }
