<view class="page launch-page">
  <view class="brand">
    <image class="brand-logo" src="/assets/brand/logo.png" mode="aspectFit" aria-role="img" aria-label="药灵通品牌标识"/>
    <text class="brand-title">药灵通</text>
    <text class="brand-subtitle">每一次按时服药，都有人安心守护</text>
  </view>

  <block wx:if="{{needLogin}}">
    <view class="login-only">
      <button class="wx-login-btn" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="login" hover-class="wx-login-btn--pressed" aria-role="button" aria-label="微信登录">
        <view class="wx-login-inner">
          <image class="wx-login-icon" src="/assets/icons/wechat-white.png" mode="aspectFit" aria-hidden="true"/>
          <text class="wx-login-text">微信登录</text>
        </view>
      </button>
      <text wx:if="{{error}}" class="danger-text form-error login-error">{{error}}</text>
    </view>
  </block>

  <view wx:elif="{{loading}}" class="card loading-card" aria-role="status" aria-live="polite">
    <view class="loading-pulse"><view class="pulse-dot"></view><view class="pulse-dot delay-1"></view><view class="pulse-dot delay-2"></view></view>
    <text class="loading-text">{{loadingText}}</text>
  </view>

  <view wx:elif="{{error && !user}}" class="card">
    <text class="danger-text">{{error}}</text>
    <button class="btn primary block retry-btn" bindtap="login">重新登录</button>
  </view>

  <block wx:else>
    <view class="card welcome-card">
      <view class="profile-row">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" disabled="{{uploadingAvatar || savingProfile}}" aria-role="button" aria-label="选择微信头像">
          <image wx:if="{{displayAvatarUrl}}" class="profile-avatar" src="{{displayAvatarUrl}}" mode="aspectFill"/>
          <view wx:else class="profile-avatar monogram">{{monogram}}</view>
          <text class="avatar-tip">换</text>
        </button>
        <view class="flex-1">
          <view class="profile-name">{{user.nickname || '微信用户'}}</view>
          <text class="list-subtitle">登录成功 · 请选择要进入的家庭空间</text>
          <view class="profile-edit-link pressable" hover-class="pressable-hover" bindtap="openProfileSheet" aria-role="button">修改头像昵称 ›</view>
        </view>
      </view>
      <text wx:if="{{profileError}}" class="danger-text form-error">{{profileError}}</text>
    </view>

    <view wx:if="{{homeError}}" class="card home-error-card" aria-role="status" aria-live="polite">
      <text class="danger-text">{{homeError}}</text>
      <button class="btn outline small" bindtap="loadHomes">重新加载</button>
    </view>

    <view wx:if="{{homes.length}}" class="section">
      <view class="section-head"><text class="section-title">我的家庭</text></view>
      <view wx:for="{{homes}}" wx:key="id" class="list-card home-card pressable" hover-class="pressable-hover" data-id="{{item.id}}" bindtap="enterHome" aria-role="button" aria-label="进入家庭 {{item.name}}">
        <view class="row between gap">
          <view class="row gap flex-1">
            <view class="home-icon {{item.role === 'elder' ? 'elder-role' : ''}}">
              <image wx:if="{{item.role === 'elder'}}" class="home-icon-img" src="/assets/icons/line-speaker.png" mode="aspectFit"/>
              <image wx:else class="home-icon-img" src="/assets/icons/line-home.png" mode="aspectFit"/>
            </view>
            <view class="flex-1">
              <text class="list-title">{{item.name}}</text>
              <text class="list-subtitle">{{item.role === 'owner' ? '家庭创建人' : item.role === 'caregiver_edit' ? '可录入家属' : item.role === 'caregiver_view' ? '只读家属' : '老人本人'}}</text>
            </view>
          </view>
          <text class="home-arrow">›</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!mode}}" class="actions-grid">
      <button class="btn primary block" data-mode="create" bindtap="chooseMode">创建家庭</button>
      <button class="btn outline block" data-mode="join" bindtap="chooseMode">用邀请码加入</button>
    </view>

    <view wx:if="{{mode === 'create'}}" class="card form-card">
      <text class="list-title">创建家庭</text>
      <view class="field first-field">
        <text class="field-label required">家庭名称</text>
        <input class="input" maxlength="50" value="{{homeName}}" placeholder="如：李家用药照护" bindinput="onHomeName"/>
      </view>
      <text wx:if="{{error}}" class="danger-text form-error">{{error}}</text>
      <view class="form-actions">
        <button class="btn" bindtap="closeMode">取消</button>
        <button class="btn primary" loading="{{submitting}}" bindtap="createHome">创建</button>
      </view>
    </view>

    <view wx:if="{{mode === 'join'}}" class="card form-card">
      <text class="list-title">加入家庭</text>
      <view class="field first-field">
        <text class="field-label required">8 位邀请码</text>
        <input class="input invite-input" maxlength="8" value="{{inviteCode}}" placeholder="请输入家属发来的邀请码" bindinput="onInviteCode"/>
      </view>
      <text wx:if="{{error}}" class="danger-text form-error">{{error}}</text>
      <view class="form-actions">
        <button class="btn" bindtap="closeMode">取消</button>
        <button class="btn primary" loading="{{submitting}}" bindtap="joinHome">加入</button>
      </view>
    </view>
  </block>

  <!-- 登录后资料弹层：使用微信头像和昵称（对齐 Map of Us / 官方头像昵称填写） -->
  <view wx:if="{{showProfileSheet}}" class="profile-mask" catchtouchmove="noop">
    <view class="profile-sheet" aria-role="dialog" aria-modal="true" aria-label="使用微信头像和昵称">
      <text class="sheet-title">使用微信头像和昵称</text>
      <text class="sheet-desc">点头像可选微信头像，点输入框可一键填入微信昵称</text>

      <button class="sheet-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" disabled="{{uploadingAvatar || savingProfile}}" aria-role="button" aria-label="选择微信头像">
        <image wx:if="{{sheetAvatarUrl || displayAvatarUrl}}" class="sheet-avatar" src="{{sheetAvatarUrl || displayAvatarUrl}}" mode="aspectFill"/>
        <view wx:else class="sheet-avatar monogram">{{monogram}}</view>
        <text class="sheet-avatar-tip" aria-live="polite">{{uploadingAvatar ? '上传中…' : '选择头像'}}</text>
      </button>

      <form bindsubmit="confirmProfile">
        <input
          class="input sheet-nickname"
          name="nickname"
          type="nickname"
          maxlength="20"
          value="{{nickInput}}"
          placeholder="点击填写微信昵称"
          bindinput="onNickInput"
          bindnicknamereview="onNicknameReview"
        />

        <text wx:if="{{profileError}}" class="danger-text form-error" aria-live="polite">{{profileError}}</text>

        <button class="btn primary block sheet-done" form-type="submit" loading="{{savingProfile}}" disabled="{{savingProfile || uploadingAvatar}}">完成</button>
      </form>
      <button class="sheet-skip" disabled="{{savingProfile || uploadingAvatar}}" bindtap="closeProfileSheet">暂时跳过</button>
    </view>
  </view>
</view>
