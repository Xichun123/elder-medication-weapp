.launch-page { padding-top: 64rpx; }
.brand { text-align: center; margin: 24rpx 0 48rpx; }
.brand-logo { width: 168rpx; height: 168rpx; margin-bottom: 18rpx; border-radius: 42rpx; background: #F3FBFA; box-shadow: 0 14rpx 30rpx rgba(23,107,91,.14); }
.brand-title { display: block; font-size: 52rpx; font-weight: 750; letter-spacing: 2rpx; color: var(--text); }
.brand-subtitle { display: block; margin-top: 10rpx; color: var(--muted); font-size: 28rpx; }

.login-only { margin-top: 72rpx; padding: 0 48rpx; }
.wx-login-btn {
  margin: 0;
  padding: 0;
  width: 100%;
  min-height: 104rpx;
  border-radius: 999rpx;
  background: #07C160;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, .24);
  line-height: 1;
}
.wx-login-btn::after { border: 0; }
.wx-login-btn[disabled] { opacity: .72; }
.wx-login-btn--pressed { opacity: .92; transform: scale(.985); }
.wx-login-inner { min-height: 104rpx; display: flex; align-items: center; justify-content: center; gap: 14rpx; }
.wx-login-icon { width: 44rpx; height: 44rpx; flex: none; }
.wx-login-text { color: #fff; font-size: 34rpx; font-weight: 700; letter-spacing: 2rpx; }
.login-error { display: block; margin-top: 20rpx; text-align: center; }

.loading-card { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 48rpx 30rpx; color: var(--muted); }
.loading-pulse { display: flex; gap: 14rpx; }
.pulse-dot { width: 18rpx; height: 18rpx; border-radius: 50%; background: var(--primary); opacity: .25; animation: pulse 1.1s infinite ease-in-out; }
.pulse-dot.delay-1 { animation-delay: .18s; }
.pulse-dot.delay-2 { animation-delay: .36s; }
@keyframes pulse { 0%,100% { opacity: .25; transform: scale(1); } 50% { opacity: 1; transform: scale(1.25); } }
.loading-text { font-size: 27rpx; }
.retry-btn { margin-top: 28rpx; }

.welcome-card { margin-bottom: 30rpx; }
.home-error-card { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-bottom: 30rpx; }
.profile-row { display: flex; align-items: flex-start; gap: 22rpx; }
.avatar-btn {
  margin: 0;
  padding: 0;
  width: 120rpx;
  min-width: 120rpx;
  max-width: 120rpx;
  height: 120rpx;
  min-height: 120rpx;
  max-height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--soft);
  position: relative;
  line-height: 1;
  flex: none;
}
.avatar-btn::after { border: 0; }
.profile-avatar { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #fff; }
.profile-avatar.monogram { color: var(--primary); font-size: 44rpx; font-weight: 700; background: var(--primary-soft); }
.avatar-tip {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 6rpx 0 8rpx;
  background: rgba(24,48,43,.68);
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
}
.profile-name { display: block; font-size: 34rpx; font-weight: 700; line-height: 1.3; }
.profile-edit-link { margin-top: 12rpx; color: var(--primary); font-size: 26rpx; font-weight: 600; }

.profile-mask {
  position: fixed;
  z-index: 100;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(24, 48, 43, .48);
}
.profile-sheet {
  width: 100%;
  max-width: 680rpx;
  margin-bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 40rpx 36rpx 28rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 20rpx 48rpx rgba(24, 48, 43, .18);
  text-align: center;
}
.sheet-title { display: block; font-size: 36rpx; font-weight: 750; color: var(--text); }
.sheet-desc { display: block; margin-top: 10rpx; color: var(--muted); font-size: 26rpx; line-height: 1.5; }
.sheet-avatar-btn {
  margin: 36rpx auto 0;
  padding: 0;
  width: 168rpx;
  min-width: 168rpx;
  max-width: 168rpx;
  height: 168rpx;
  min-height: 168rpx;
  max-height: 168rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--soft);
  position: relative;
  line-height: 1;
  flex: none;
}
.sheet-avatar-btn::after { border: 0; }
.sheet-avatar {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
}
.sheet-avatar.monogram { color: var(--primary); font-size: 56rpx; font-weight: 700; background: var(--primary-soft); }
.sheet-avatar-tip {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  padding: 10rpx 0;
  background: rgba(24, 48, 43, .58);
  color: #fff;
  font-size: 26rpx;
}
.sheet-nickname { margin-top: 28rpx; text-align: left; }
.sheet-done { margin-top: 28rpx; }
.sheet-skip {
  width: 100%;
  min-height: 88rpx;
  margin: 8rpx 0 0;
  padding: 0;
  background: transparent;
  color: var(--muted);
  font-size: 28rpx;
  line-height: 88rpx;
}
.sheet-skip::after { border: 0; }
.sheet-skip[disabled] { opacity: .45; }

.home-card { margin-bottom: 16rpx; }
.home-icon { width: 76rpx; height: 76rpx; display: flex; align-items: center; justify-content: center; border-radius: 22rpx; background: var(--primary-soft); }
.home-icon.elder-role { background: var(--accent-soft); }
.home-icon-img { width: 44rpx; height: 44rpx; }
.home-arrow { color: var(--light); font-size: 44rpx; }
.actions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 32rpx; }
.first-field { margin-top: 26rpx; }
.form-error { display: block; margin-top: 12rpx; font-size: 26rpx; }
.invite-input { text-transform: uppercase; letter-spacing: 8rpx; }
