.family-picker { padding: 12rpx 18rpx; border-radius: 14rpx; background: rgba(255,255,255,.18); font-size: 23rpx; }
.quick-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14rpx; }
.quick { min-height: 142rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; background: #fff; border: 1rpx solid var(--border); border-radius: 20rpx; font-size: 23rpx; }
.quick-icon { font-size: 40rpx; }
.elder-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 10rpx; margin-top: 22rpx; padding-top: 18rpx; border-top: 1rpx dashed var(--border); text-align: center; }
.stat-number { display: block; font-size: 36rpx; line-height: 1.1; font-weight: 700; }
.stat-number.warning { color: var(--warning); }.stat-number.danger { color: var(--danger); }
.stat-label { display: block; color: var(--muted); font-size: 21rpx; margin-top: 5rpx; }
.compact-card { padding-top: 4rpx; padding-bottom: 4rpx; }
.record-row { display: flex; align-items: center; gap: 14rpx; padding: 22rpx 0; border-bottom: 1rpx solid var(--border); }
.record-row:last-child { border-bottom: 0; }.list-title.small { font-size: 28rpx; }
