/* Hero 铃铛 */
.hero-bell { position: relative; width: 88rpx; height: 88rpx; flex: none; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,.92); }
.hero-bell-icon { width: 44rpx; height: 44rpx; }
.hero-bell-dot { position: absolute; top: -8rpx; right: -10rpx; min-width: 36rpx; height: 36rpx; padding: 0 10rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #fff; background: var(--danger); font-size: 22rpx; line-height: 1; }

/* 长辈卡内 3 列统计 */
.elder-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-top: 24rpx; padding-top: 22rpx; border-top: 1rpx dashed var(--border); text-align: center; }
.elder-stats .stat-number { font-size: 38rpx; }

/* 最近用药 */
.compact-card { padding-top: 6rpx; padding-bottom: 6rpx; }
.record-row { display: flex; align-items: center; gap: 14rpx; padding: 24rpx 0; border-bottom: 1rpx solid var(--border); }
.record-row:last-child { border-bottom: 0; }

/* 底部关怀横幅 */
.care-banner { position: relative; overflow: hidden; margin-top: 36rpx; height: 240rpx; border-radius: 32rpx; }
.care-banner-img { position: absolute; inset: 0; width: 100%; height: 100%; }
.care-banner-text { position: absolute; top: 50%; right: 40rpx; transform: translateY(-50%); text-align: right; }
.care-banner-title { display: block; color: #A65B33; font-size: 36rpx; font-weight: 700; text-shadow: 0 2rpx 8rpx rgba(255,255,255,.8); }
.care-banner-desc { display: block; margin-top: 6rpx; color: #8A6A4C; font-size: 26rpx; text-shadow: 0 2rpx 8rpx rgba(255,255,255,.8); }
