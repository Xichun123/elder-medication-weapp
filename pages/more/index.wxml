<view class="page with-tabbar">
  <!-- 个人信息卡 -->
  <view class="profile-card">
    <view class="profile-avatar">
      <image wx:if="{{avatarUrl}}" class="profile-avatar-img" src="{{avatarUrl}}" mode="aspectFill" aria-role="img" aria-label="我的头像"/>
      <view wx:else class="profile-avatar-fallback" aria-role="img" aria-label="我的头像">{{nicknameInitial}}</view>
    </view>
    <view class="flex-1">
      <text class="profile-name">{{nickname || '微信用户'}}</text>
      <text class="profile-sub">{{isRemote ? (homeName || '云端家庭') + (roleText ? ' · ' + roleText : '') : '独立离线版 · 数据保存在本机'}}</text>
    </view>
  </view>

  <!-- 家庭与协作 -->
  <view class="section">
    <view class="section-head"><text class="section-title">家庭与协作</text></view>
    <view class="menu-card" aria-label="家庭与协作菜单">
      <view wx:if="{{isRemote}}" class="menu-row pressable" hover-class="pressable-hover" bindtap="openCloudHome" aria-role="button" aria-label="家庭管理">
        <view class="menu-icon"><image src="/assets/icons/line-home.png" mode="aspectFit"/></view>
        <text class="menu-label">家庭管理</text>
        <text class="menu-value">邀请码 · 长辈建档</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-row pressable" hover-class="pressable-hover" data-path="/pages/relations/index" bindtap="navigate" aria-role="button" aria-label="{{isRemote ? '成员管理' : '家属关联'}}">
        <view class="menu-icon blue"><image src="/assets/icons/line-people.png" mode="aspectFit"/></view>
        <text class="menu-label">{{isRemote ? '成员管理' : '家属关联'}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-row pressable" hover-class="pressable-hover" data-path="/pages/records/index" bindtap="navigate" aria-role="button" aria-label="用药记录">
        <view class="menu-icon orange"><image src="/assets/icons/line-list.png" mode="aspectFit"/></view>
        <text class="menu-label">用药记录</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 数据与工具 -->
  <view class="section">
    <view class="section-head"><text class="section-title">数据与工具</text></view>
    <view class="menu-card" aria-label="数据与工具菜单">
      <view class="menu-row pressable" hover-class="pressable-hover" data-path="/pages/admin-drugs/index" bindtap="navigate" aria-role="button" aria-label="药物主数据">
        <view class="menu-icon"><image src="/assets/icons/line-pill.png" mode="aspectFit"/></view>
        <text class="menu-label">药物主数据</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-row pressable" hover-class="pressable-hover" data-path="/pages/admin-contraindications/index" bindtap="navigate" aria-role="button" aria-label="禁忌管理">
        <view class="menu-icon pink"><image src="/assets/icons/line-warning.png" mode="aspectFit"/></view>
        <text class="menu-label">禁忌管理</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-row pressable" hover-class="pressable-hover" data-path="/pages/dictionary/index" bindtap="navigate" aria-role="button" aria-label="数据字典">
        <view class="menu-icon blue"><image src="/assets/icons/line-book.png" mode="aspectFit"/></view>
        <text class="menu-label">数据字典</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 数据概况 -->
  <view class="section">
    <view class="section-head">
      <text class="section-title">数据概况</text>
      <text class="tag {{isRemote ? 'primary' : 'success'}}">{{isRemote ? '云端同步' : '本机保存'}}</text>
    </view>
    <view class="card">
      <view class="data-grid">
        <view><text class="data-number">{{stats.elders}}</text><text class="data-label">长辈</text></view>
        <view><text class="data-number">{{stats.records}}</text><text class="data-label">用药</text></view>
        <view><text class="data-number">{{stats.reminders}}</text><text class="data-label">提醒</text></view>
        <view><text class="data-number">{{stats.drugs}}</text><text class="data-label">药物</text></view>
        <view><text class="data-number">{{stats.contraindications}}</text><text class="data-label">禁忌</text></view>
        <view><text class="data-number">{{stats.families}}</text><text class="data-label">{{isRemote ? '家庭' : '家属'}}</text></view>
      </view>
      <view wx:if="{{!isRemote}}" class="form-actions">
        <button class="btn" bindtap="exportData">复制 JSON 备份</button>
        <button class="btn danger" loading="{{resetting}}" bindtap="resetData">恢复初始数据</button>
      </view>
      <view wx:else class="form-actions">
        <button class="btn" bindtap="switchHome">切换家庭</button>
        <button class="btn danger" bindtap="logout">退出登录</button>
      </view>
    </view>
  </view>

  <view class="notice disclaimer">药品与禁忌数据仅供学习参考，不能替代医生诊断。实际用药请遵医嘱。</view>
</view>
