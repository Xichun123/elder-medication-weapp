.menu { margin-top: 24rpx; padding-top: 4rpx; padding-bottom: 4rpx; }.menu-item { display:flex; align-items:center; gap:18rpx; padding:26rpx 0; border-bottom:1rpx solid var(--border); }.menu-item:last-child { border-bottom:0; }.menu-icon { width:60rpx; text-align:center; font-size:42rpx; }.data-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12rpx; text-align:center; }.data-grid > view { padding:18rpx 6rpx; border-radius:14rpx; background:var(--soft); }.data-number { display:block; font-size:38rpx; font-weight:700; color:var(--primary); }.data-label { display:block; color:var(--muted); font-size:22rpx; }.local-notice { margin-top:22rpx; }.disclaimer { margin-top:30rpx; }
