.search-row { display: flex; gap: 14rpx; align-items: center; background: #fff; border-radius: 32rpx; padding: 20rpx; box-shadow: 0 12rpx 36rpx rgba(46, 92, 66, .10); }
.search-row .search { box-shadow: none; background: #F7FAF5; }
.search-btn { flex: none; min-height: 88rpx; }
.allergy { margin-top: 18rpx; padding: 16rpx 22rpx; border-radius: 18rpx; color: var(--danger); background: var(--danger-soft); font-size: 26rpx; line-height: 1.5; }
