.hero-avatar { width: 140rpx; height: 140rpx; border-radius: 50%; overflow: hidden; background: rgba(255,255,255,.95); flex: none; border: 6rpx solid rgba(255,255,255,.6); }
.hero-avatar-img { width: 100%; height: 100%; display: block; }
.hero-allergy { margin-top: 22rpx; padding: 16rpx 24rpx; border-radius: 20rpx; background: rgba(255,255,255,.22); font-size: 26rpx; }
.hero-actions { display: flex; margin-top: 26rpx; }
.hero-btn { flex: 1; min-height: 88rpx; border-radius: 999rpx; font-size: 28rpx; font-weight: 600; }
.hero-btn.solid { background: #fff; color: var(--primary-deep); }
.risk { border-left: 8rpx solid var(--border); }
.risk.severe { border-left-color: var(--danger); }
.risk.middle { border-left-color: var(--warning); }
.risk.light { border-left-color: var(--success); }
.risk-note { margin-top: 14rpx; color: var(--text); font-size: 26rpx; line-height: 1.6; }
