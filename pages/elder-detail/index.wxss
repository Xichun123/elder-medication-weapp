.hero-avatar { width: 120rpx; height: 120rpx; display: flex; align-items: center; justify-content: center; border-radius: 24rpx; background: rgba(255,255,255,.18); font-size: 68rpx; }.hero-allergy { margin-top: 20rpx; padding: 14rpx 18rpx; border-radius: 14rpx; background: rgba(255,255,255,.2); }.hero-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 24rpx; }.hero-btn { min-height: 72rpx; border: 2rpx solid rgba(255,255,255,.7); border-radius: 16rpx; background: rgba(255,255,255,.14); color: #fff; font-size: 25rpx; }.hero-btn.solid { background: #fff; color: var(--primary); }.risk { border-left: 8rpx solid var(--border); }.risk.severe { border-left-color: var(--danger); }.risk.middle { border-left-color: var(--warning); }.risk.light { border-left-color: var(--success); }.risk-note { margin-top: 12rpx; color: var(--muted); font-size: 24rpx; }
