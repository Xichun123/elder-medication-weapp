.hero-avatar { width: 132rpx; height: 132rpx; border-radius: 26rpx; overflow: hidden; background: rgba(255,255,255,.9); flex: none; }
.hero-avatar-img { width: 100%; height: 100%; display: block; }
.hero-allergy { margin-top: 22rpx; padding: 16rpx 20rpx; border-radius: 16rpx; background: rgba(255,255,255,.2); font-size: 26rpx; }
.hero-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 26rpx; }
.hero-btn { min-height: 88rpx; border: 2rpx solid rgba(255,255,255,.7); border-radius: 18rpx; background: rgba(255,255,255,.14); color: #fff; font-size: 28rpx; }
.hero-btn.solid { background: #fff; color: var(--primary); }
.risk { border-left: 8rpx solid var(--border); }
.risk.severe { border-left-color: var(--danger); }
.risk.middle { border-left-color: var(--warning); }
.risk.light { border-left-color: var(--success); }
.risk-note { margin-top: 14rpx; color: var(--text); font-size: 26rpx; line-height: 1.6; }
