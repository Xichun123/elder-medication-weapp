.elderly-page { min-height: 100vh; padding-bottom: 50rpx; background: var(--bg); }.elderly-page.high-contrast { --bg:#fff; --text:#000; --muted:#222; --border:#000; background:#fff; color:#000; }.elderly-tools { display:flex; justify-content:space-between; gap:14rpx; padding:20rpx 24rpx; background:#fff; border-bottom:2rpx solid var(--border); }.tool-btn { min-height:68rpx; padding:0 20rpx; display:flex; align-items:center; border:2rpx solid var(--border); border-radius:14rpx; background:#fff; color:var(--text); font-size:27rpx; }.elderly-main { padding:30rpx 24rpx; }.greeting { display:flex; align-items:center; gap:20rpx; margin-bottom:32rpx; }.greeting-avatar { font-size:94rpx; }.elder-title { display:block; font-size:48rpx; font-weight:700; }.elder-sub { display:block; color:var(--muted); font-size:30rpx; }.current-card { padding:48rpx 30rpx; color:#fff; text-align:center; border-radius:30rpx; background:linear-gradient(135deg,var(--primary),var(--primary-deep)); box-shadow:0 16rpx 36rpx rgba(232,122,93,.23); }.current-card.resting { background:linear-gradient(135deg,#6fbbac,#5ba89a); }.current-label { display:block; font-size:32rpx; }.current-drug { display:block; margin:14rpx 0; font-size:66rpx; line-height:1.15; font-weight:700; }.current-voice { display:block; margin:24rpx 0; padding:20rpx; border-radius:18rpx; background:rgba(255,255,255,.18); font-size:34rpx; }.play-btn { min-height:92rpx; padding:0 40rpx; border:3rpx solid #fff; border-radius:22rpx; background:rgba(255,255,255,.16); color:#fff; font-size:34rpx; font-weight:650; }.current-tip { display:block; margin-top:20rpx; opacity:.86; font-size:25rpx; }.today { margin-top:38rpx; }.elder-section-title { display:block; margin-bottom:18rpx; font-size:40rpx; font-weight:700; }.elder-reminder { display:flex; align-items:center; justify-content:space-between; gap:20rpx; margin-bottom:16rpx; padding:28rpx; border:3rpx solid var(--border); border-radius:22rpx; background:#fff; }.elder-reminder.taken,.elder-reminder.skipped { opacity:.62; }.reminder-time { display:block; color:var(--primary); font-size:38rpx; font-weight:700; }.reminder-drug { display:block; font-size:32rpx; }.reminder-status { font-size:28rpx; }.elder-empty { padding:50rpx; text-align:center; font-size:32rpx; }.auto-card { margin-top:34rpx; padding:28rpx; border:3rpx solid var(--border); border-radius:22rpx; background:#fff; }.auto-title { display:block; font-size:34rpx; font-weight:700; }.auto-desc { display:block; color:var(--muted); font-size:26rpx; }.auto-tip { margin-top:18rpx; padding:18rpx; border-radius:14rpx; background:var(--success-soft); color:var(--success); font-size:26rpx; }.elderly-loading { font-size:34rpx; }
.current-package-image,.current-package-placeholder { width:100%; height:360rpx; margin:24rpx 0; border-radius:18rpx; background:#fff; }
.current-package-placeholder { display:flex; align-items:center; justify-content:center; color:#64483f; font-size:30rpx; }
.current-dose { display:block; font-size:36rpx; font-weight:650; }
