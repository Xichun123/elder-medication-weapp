<view class="elderly-page {{highContrast ? 'high-contrast' : ''}}">
  <view class="elderly-tools">
    <picker range="{{elders}}" range-key="name" value="{{elderIndex}}" bindchange="onElderChange">
      <view class="tool-btn" aria-role="button" aria-label="切换长辈">{{elderIndex >= 0 ? elders[elderIndex].name + ' 长辈' : '选择长辈'}} ›</view>
    </picker>
    <button class="tool-btn" bindtap="toggleContrast">{{highContrast ? '标准模式' : '高对比'}}</button>
  </view>

  <view wx:if="{{elder}}" class="elderly-main">
    <view class="ai-entry" bindtap="openAi" hover-class="ai-entry--pressed" aria-role="button" aria-label="语音用药助手，点这里直接说话">
      <view class="ai-entry-icon"><image class="ai-entry-icon-img" src="/assets/icons/line-mic.png" mode="aspectFit"/></view>
      <view class="ai-entry-main">
        <text class="ai-entry-title">语音用药助手</text>
        <text class="ai-entry-desc">说“我刚吃了药”或“我头晕”</text>
      </view>
      <view class="ai-entry-arrow">›</view>
    </view>

    <view class="greeting">
      <image class="greeting-avatar" src="{{elder.gender === 'male' ? '/assets/brand/avatar-grandpa.png' : '/assets/brand/avatar-grandma.png'}}" mode="aspectFit" aria-role="img" aria-label="长辈头像"/>
      <view class="greeting-copy">
        <text class="elder-title">您好，{{elder.name}}</text>
        <text class="elder-sub">{{greeting}}，今天是 {{today}}</text>
      </view>
    </view>

    <view wx:if="{{currentReminder}}" class="current-card">
      <view class="current-top">
        <text class="current-label">当前待服</text>
        <text class="current-time-chip">{{currentReminder.remind_time}}</text>
      </view>
      <image wx:if="{{currentReminder.package_image_url}}" class="current-package-image" src="{{currentReminder.package_image_url}}" mode="aspectFit"/>
      <view wx:else class="current-package-placeholder">暂无药品包装照片</view>
      <text class="current-drug">{{currentReminder.drug_name}}</text>
      <text wx:if="{{currentReminder.dose}}" class="current-dose">剂量：{{currentReminder.dose}}</text>
      <text class="current-voice">{{currentReminder.voice_text}}</text>
      <view class="current-actions">
        <button class="play-btn" bindtap="playCurrent">再听一次</button>
        <button class="play-btn primary" loading="{{acting}}" catchtap="takeCurrent">已核对药盒，我已服药</button>
      </view>
      <text class="current-tip">请对照包装、药名与剂量，散装药片不能仅凭外观确认</text>
    </view>
    <view wx:else class="current-card resting">
      <text class="current-label">今日状态</text>
      <text class="current-drug">今日已无待服提醒</text>
      <text class="current-rest-desc">请安心休息。家属端可看到您已确认的服药状态。</text>
    </view>

    <view class="today">
      <view class="section-head-row">
        <text class="elder-section-title">今日提醒</text>
        <text class="section-count">共 {{reminders.length}} 条</text>
      </view>

      <view wx:for="{{reminders}}" wx:key="rule_id" class="reminder-card {{item.status}}">
        <view class="reminder-head">
          <view class="reminder-time-wrap">
            <text class="reminder-time">{{item.remind_time}}</text>
            <text wx:if="{{item.dose}}" class="reminder-dose">{{item.dose}}</text>
          </view>
          <text class="status-badge {{item.status}}">{{item.status === 'pending' ? '待服' : item.status === 'taken' ? '已服' : item.status === 'skipped' ? '已跳过' : '异常'}}</text>
        </view>

        <text class="reminder-drug">{{item.drug_name}}</text>

        <view class="reminder-actions">
          <button class="action-btn ghost" data-id="{{item.rule_id}}" bindtap="playReminder">播报</button>
          <button
            wx:if="{{item.status === 'pending'}}"
            class="action-btn solid"
            loading="{{acting}}"
            data-id="{{item.rule_id}}"
            catchtap="takeReminder"
          >确认已服</button>
          <view wx:else class="action-done">
            <text class="action-done-text">{{item.status === 'taken' ? '今日已确认' : '今日已跳过'}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!reminders.length}}" class="elder-empty">今日暂无提醒，请安心休息</view>
    </view>

    <view class="auto-card">
      <view class="auto-row">
        <view class="auto-copy">
          <text class="auto-title">自动提醒播报</text>
          <text class="auto-desc">每分钟检查并播报待服提醒</text>
        </view>
        <switch checked="{{autoPlay}}" color="#3EAE5B" bindchange="onAutoChange" aria-label="自动提醒播报开关"/>
      </view>
      <view wx:if="{{autoPlay}}" class="auto-tip">已开启，下一条提醒：{{nextReminder ? nextReminder.remind_time + ' ' + nextReminder.drug_name : '无'}}</view>
    </view>
  </view>

  <view wx:else class="loading elderly-loading" aria-role="status">请稍候…</view>
</view>
