.alert-notice { margin-top: 22rpx; }
.alert-card { margin-top: 20rpx; padding: 26rpx; border: 1rpx solid var(--border); border-left: 8rpx solid var(--warning); border-radius: 22rpx; background: #fff; box-shadow: 0 4rpx 16rpx rgba(24,48,43,.04); }
.alert-card.urgent { border-left-color: var(--danger); }
.alert-card.read { opacity: .72; }
.alert-card.unread { background: linear-gradient(135deg,#fff,#FFF8F4); }
.severity-icon { width: 76rpx; height: 76rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 22rpx; background: var(--warning-soft); }
.severity-icon.is-urgent { background: var(--danger-soft); }
.severity-icon-img { width: 44rpx; height: 44rpx; }
.alert-content { display: block; margin-top: 12rpx; font-size: 28rpx; line-height: 1.6; }
.unread-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--danger); }
.urgent-tip { margin-top: 18rpx; padding: 18rpx 20rpx; color: var(--danger); background: var(--danger-soft); border-radius: 16rpx; font-size: 26rpx; line-height: 1.55; }
