.hero-metrics.three { grid-template-columns: repeat(3,1fr); }.selector { margin-top: 20rpx; }.allergy { margin-top: 20rpx; padding: 24rpx; border: 2rpx solid var(--danger); border-radius: 18rpx; background: var(--danger-soft); color: var(--danger); }.allergy-title { display: block; font-size: 29rpx; font-weight: 700; }.med-scroll { width: 100%; white-space: nowrap; }.med-row { display: inline-flex; gap: 14rpx; padding-bottom: 6rpx; }.med-card { width: 280rpx; padding: 22rpx; border: 1rpx solid var(--border); border-radius: 18rpx; background: #fff; white-space: normal; }.med-name { display: block; margin: 12rpx 0 4rpx; font-size: 29rpx; font-weight: 650; }.filter-chips { display: flex; flex-wrap: wrap; gap: 10rpx; }.filter-chips.type { margin-top: 12rpx; }.choice { padding: 10rpx 18rpx; }.danger-choice.active { color: var(--danger); border-color: var(--danger); background: var(--danger-soft); }.risk-group-title { margin-bottom: 14rpx; font-size: 30rpx; font-weight: 700; }.risk-group-title.severe { color: var(--danger); }.risk-group-title.middle { color: var(--warning); }.risk-group-title.light { color: var(--success); }.risk { border-left: 9rpx solid var(--border); }.risk.severe { border-left-color: var(--danger); background: linear-gradient(90deg,var(--danger-soft),#fff 45%); }.risk.middle { border-left-color: var(--warning); }.risk.light { border-left-color: var(--success); }.risk-pair { display: flex; align-items: center; gap: 14rpx; font-size: 30rpx; font-weight: 650; }.times { color: var(--light); }.risk-note { margin-top: 14rpx; color: var(--muted); font-size: 25rpx; }.disclaimer { margin-top: 30rpx; }
