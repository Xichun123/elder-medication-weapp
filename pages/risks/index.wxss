.risk-header { margin-top: 10rpx; margin-bottom: 22rpx; }
.selector { margin-top: 20rpx; }
.risk-summary { margin-top: 20rpx; }
.risk-summary-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.risk-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 14rpx; margin-top: 22rpx; }
.risk-stat { display: flex; flex-direction: column; align-items: center; gap: 6rpx; padding: 20rpx 8rpx; border-radius: 20rpx; background: var(--soft); }
.risk-stat.severe { background: var(--danger-soft); }
.risk-stat.middle { background: var(--warning-soft); }
.risk-stat.light { background: var(--success-soft); }
.risk-stat-num { font-size: 44rpx; font-weight: 750; line-height: 1.1; }
.risk-stat.severe .risk-stat-num { color: var(--danger); }
.risk-stat.middle .risk-stat-num { color: var(--warning-deep); }
.risk-stat.light .risk-stat-num { color: var(--primary-deep); }
.risk-stat-label { color: var(--muted); font-size: 24rpx; }
.allergy { display: flex; align-items: flex-start; gap: 16rpx; margin-top: 22rpx; padding: 24rpx; border: 2rpx solid var(--danger); border-radius: 18rpx; background: var(--danger-soft); color: var(--danger); font-size: 27rpx; line-height: 1.55; }
.allergy-icon { width: 40rpx; height: 40rpx; flex: none; margin-top: 4rpx; }
.allergy-title { display: block; font-size: 29rpx; font-weight: 700; }
.med-scroll { width: 100%; white-space: nowrap; }
.med-row { display: inline-flex; gap: 14rpx; padding-bottom: 8rpx; }
.med-card { width: 280rpx; padding: 22rpx; border: 1rpx solid var(--border); border-radius: 18rpx; background: #fff; white-space: normal; }
.med-name { display: block; margin: 12rpx 0 4rpx; font-size: 29rpx; font-weight: 650; }
.filter-chips { display: flex; flex-wrap: wrap; gap: 12rpx; }
.filter-chips.type { margin-top: 12rpx; }
.danger-choice.active { color: var(--danger); border-color: var(--danger); background: var(--danger-soft); }
.risk-group-title { margin-bottom: 14rpx; font-size: 30rpx; font-weight: 700; }
.risk-group-title.severe { color: var(--danger); }
.risk-group-title.middle { color: var(--warning); }
.risk-group-title.light { color: var(--success); }
.risk { border-left: 9rpx solid var(--border); }
.risk.severe { border-left-color: var(--danger); background: linear-gradient(90deg,var(--danger-soft),#fff 45%); }
.risk.middle { border-left-color: var(--warning); }
.risk.light { border-left-color: var(--success); }
.risk-pair { display: flex; align-items: center; gap: 14rpx; font-size: 30rpx; font-weight: 650; }
.times { color: var(--light); }
.risk-note { margin-top: 14rpx; color: var(--text); font-size: 27rpx; line-height: 1.6; }
.disclaimer { margin-top: 32rpx; }
