.ai-page { min-height:100vh; display:flex; flex-direction:column; padding-bottom:168rpx; }
.notice { margin:24rpx 28rpx 14rpx; padding:18rpx 20rpx; background:var(--warning-soft); border:1rpx solid #EBD9BC; border-radius:18rpx; color:var(--text); font-size:26rpx; line-height:1.55; }
.elder-picker { display:flex; align-items:center; justify-content:space-between; margin:0 28rpx 18rpx; padding:20rpx 22rpx; border-radius:18rpx; background:#fff; border:1rpx solid var(--border); color:var(--muted); font-size:26rpx; }
.elder-picker-value { min-height:64rpx; display:flex; align-items:center; color:var(--primary); font-weight:650; font-size:28rpx; }
.elder-picker-value text { margin-left:12rpx; color:var(--light); font-size: 26rpx; }
.phrases { display:flex; gap:14rpx; padding:0 28rpx 18rpx; }
.phrases button { flex:1; margin:0; min-height:80rpx; border-radius:999rpx; font-size:26rpx; color:var(--primary); background:#fff; border:1rpx solid #B9DED4; }
.chat { flex:1; box-sizing:border-box; padding:8rpx 28rpx; }
.bubble-wrap { display:flex; }
.bubble-wrap.user { justify-content:flex-end; }
.bubble { max-width:86%; margin:16rpx 0; padding:22rpx 24rpx; border-radius:22rpx; white-space:pre-wrap; line-height:1.6; font-size:28rpx; box-sizing:border-box; }
.bubble.assistant { background:#fff; color:var(--text); border:1rpx solid var(--border); border-top-left-radius:6rpx; }
.bubble.user { background:var(--primary); color:#fff; border-top-right-radius:6rpx; }
.play-audio { display:inline-flex; align-items:center; gap:10rpx; margin-top:16rpx; padding:12rpx 20rpx; min-height:64rpx; border-radius:999rpx; background:var(--ai-soft); color:var(--ai); font-size:26rpx; font-weight:650; }
.play-audio-icon { width:32rpx; height:32rpx; }
.confirm-card,.candidate-list { margin-top:22rpx; padding:20rpx; border:2rpx solid var(--border); border-radius:20rpx; background:#FBFDFC; }
.package-image,.package-placeholder { width:100%; height:240rpx; border-radius:16rpx; background:var(--soft); }
.package-placeholder { display:flex; align-items:center; justify-content:center; color:var(--muted); font-size:26rpx; }
.confirm-title { display:block; margin-top:16rpx; font-size:32rpx; font-weight:700; }
.confirm-meta { display:block; margin-top:8rpx; color:var(--muted); font-size:26rpx; }
.safety-warning { display:block; margin-top:16rpx; color:var(--coral); font-size:26rpx; line-height:1.55; }
.confirm-btn { margin-top:18rpx; min-height:88rpx; background:var(--primary); color:#fff; font-size:28rpx; }
.confirmed-label { margin-top:18rpx; color:var(--success); font-size:28rpx; font-weight:700; }
.candidate-heading { display:block; margin-bottom:14rpx; font-size:28rpx; font-weight:700; }
.candidate-card { display:flex; align-items:center; gap:14rpx; padding:16rpx 0; border-top:1rpx solid var(--border); }
.candidate-image,.candidate-placeholder { width:88rpx; height:88rpx; border-radius:14rpx; background:var(--soft); }
.candidate-placeholder { display:flex; align-items:center; justify-content:center; color:var(--muted); font-size: 26rpx; }
.candidate-info { flex:1; min-width:0; color:var(--muted); font-size:26rpx; }
.candidate-name { display:block; color:var(--text); font-size:28rpx; font-weight:700; }
.candidate-btn { margin:0; padding:0 24rpx; min-height:80rpx; background:var(--ai); color:#fff; font-size:26rpx; }
.composer { position:fixed; bottom:0; left:0; right:0; display:flex; align-items:center; gap:14rpx; padding:16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom)); background:#fff; border-top:1rpx solid var(--border); }
.composer input { flex:1; height:88rpx; padding:0 24rpx; box-sizing:border-box; background:#F2F7F4; border-radius:44rpx; font-size:28rpx; }
.composer button { margin:0; min-height:88rpx; background:var(--primary); color:#fff; border-radius:44rpx; font-size:28rpx; }
.composer .voice-input { width:96rpx; min-width:96rpx; height:96rpx; min-height:96rpx; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%; background:var(--ai); box-shadow:0 8rpx 20rpx rgba(93,75,195,.28); line-height:1; }
.voice-input-icon { font-size:44rpx; line-height:1; }
.voice-input-img { width:48rpx; height:48rpx; }
.composer .voice-input.recording { background:var(--danger); animation:voice-pulse 1s infinite; }
.voice-hint,.voice-status { position:fixed; left:50%; bottom:calc(140rpx + env(safe-area-inset-bottom)); z-index:2; transform:translateX(-50%); padding:14rpx 24rpx; border-radius:999rpx; white-space:nowrap; font-size:26rpx; }
.voice-hint { color:var(--primary-deep); background:var(--primary-soft); }
.voice-status { color:#fff; background:rgba(24,48,43,.88); }
@keyframes voice-pulse { 0%,100% { opacity:1; } 50% { opacity:.58; } }
.history-bar { display:flex; align-items:center; justify-content:space-between; gap:16rpx; margin:0 28rpx 14rpx; padding:14rpx 18rpx; border-radius:16rpx; background:#F2F7F4; border:1rpx solid var(--border); }
.history-tip { flex:1; color:var(--muted); font-size:24rpx; line-height:1.45; }
.history-clear { margin:0; min-height:64rpx; padding:0 22rpx; border-radius:999rpx; background:#fff; color:var(--primary); border:1rpx solid #B9DED4; font-size:24rpx; }
