.status-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10rpx; margin-top: 24rpx; }.status-card { min-width: 0; padding: 18rpx 4rpx; text-align: center; border: 2rpx solid transparent; border-radius: 18rpx; background: #fff; color: var(--muted); font-size: 21rpx; }.status-card.active { border-color: var(--primary); transform: translateY(-3rpx); }.status-num { display: block; color: var(--text); font-size: 36rpx; font-weight: 700; }.reminder { border-left: 8rpx solid var(--border); }.reminder.pending { border-left-color: var(--warning); }.reminder.taken { border-left-color: var(--success); opacity: .75; }.reminder.abnormal { border-left-color: var(--danger); }.remind-time { display: block; color: var(--primary); font-size: 30rpx; font-weight: 700; }.voice { margin-top: 18rpx; padding: 18rpx; border-radius: 14rpx; background: var(--soft); font-size: 25rpx; }
