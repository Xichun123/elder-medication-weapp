.drug-page-head { display:flex; align-items:flex-start; justify-content:space-between; gap:24rpx; }
.drug-page-copy { flex:1; min-width:0; padding-top:2rpx; }
.drug-page-head .page-title { font-size:40rpx; line-height:1.3; }
.drug-page-head .page-subtitle { margin-top:8rpx; font-size:24rpx; line-height:1.45; }
.drug-add-btn { flex:none; width:176rpx; min-height:76rpx; padding:0 12rpx; margin-top:4rpx; font-size:27rpx; box-shadow:0 6rpx 16rpx rgba(62,174,91,.22); }
.contra { margin-top:14rpx; padding:16rpx 20rpx; border-radius:14rpx; color:var(--danger); background:var(--danger-soft); font-size:26rpx; line-height:1.5; }
