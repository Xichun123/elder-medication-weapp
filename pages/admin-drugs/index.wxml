<view class="page">
  <view wx:if="{{!editing}}"><view class="row between gap"><view><text class="page-title">药物主数据</text><text class="page-subtitle">通用名 / 商品名 / 别名 / 分类 / 禁忌说明</text></view><button class="btn primary small" bindtap="openCreate">＋ 新增</button></view><view class="filter-bar"><input class="search flex-1" value="{{keyword}}" placeholder="搜索药名或别名" bindinput="onKeyword" confirm-type="search" bindconfirm="onSearch"/><picker range="{{categories}}" range-key="label" value="{{categoryIndex}}" bindchange="onCategory"><view class="filter">{{categories[categoryIndex].label}} ▾</view></picker></view><view wx:for="{{list}}" wx:key="drug_id" class="list-card"><view class="row between gap"><view class="flex-1"><text class="list-title">{{item.generic_name}}</text><view class="list-subtitle">商品名：{{item.trade_name || '—'}}</view></view><text class="tag primary">{{item.category_label}}</text></view><view class="list-meta">{{item.drug_id}} · 成分：{{item.ingredient || '—'}} · 别名：{{item.aliases || '—'}}</view><view wx:if="{{item.contraindication_note}}" class="contra">⚠️ {{item.contraindication_note}}</view><view class="actions"><button class="btn small" data-id="{{item.drug_id}}" bindtap="openEdit">编辑</button><button class="btn danger small" data-id="{{item.drug_id}}" bindtap="remove">删除</button></view></view><view wx:if="{{!loading && !list.length}}" class="card empty">暂无药物主数据</view><view wx:if="{{loading}}" class="loading">正在加载…</view></view>
  <view wx:else><text class="page-title">{{isEdit ? '编辑药物' : '新增药物'}}</text><view class="card form-card">
    <view class="field"><text class="field-label required">药物ID</text><input class="input" value="{{form.drug_id}}" disabled="{{isEdit}}" data-field="drug_id" bindinput="onInput"/></view>
    <view class="field"><text class="field-label required">通用名</text><input class="input" value="{{form.generic_name}}" data-field="generic_name" bindinput="onInput"/></view>
    <view class="field"><text class="field-label">商品名</text><input class="input" value="{{form.trade_name}}" data-field="trade_name" bindinput="onInput"/></view>
    <view class="field"><text class="field-label">别名</text><input class="input" value="{{form.aliases}}" placeholder="逗号分隔" data-field="aliases" bindinput="onInput"/></view>
    <view class="field"><text class="field-label required">分类</text><picker range="{{formCategories}}" range-key="label" value="{{formCategoryIndex}}" bindchange="onFormCategory"><view class="picker">{{formCategories[formCategoryIndex].label}} ▾</view></picker></view>
    <view class="field"><text class="field-label">主要成分</text><input class="input" value="{{form.ingredient}}" data-field="ingredient" bindinput="onInput"/></view>
    <view class="field"><text class="field-label">用法用量</text><input class="input" value="{{form.dosage_text}}" data-field="dosage_text" bindinput="onInput"/></view>
    <view class="field"><text class="field-label">禁忌说明</text><textarea class="textarea" value="{{form.contraindication_note}}" data-field="contraindication_note" bindinput="onInput"/></view>
    <view class="field"><text class="field-label">相互作用</text><textarea class="textarea" value="{{form.interaction_note}}" data-field="interaction_note" bindinput="onInput"/></view>
    <view class="form-actions"><button class="btn" bindtap="cancel">取消</button><button class="btn primary" loading="{{saving}}" bindtap="save">保存</button></view>
  </view></view>
</view>
