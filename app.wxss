page {
  /* ===== 设计 token：温暖、可信、清晰 ===== */
  --bg: #F7FAF8;
  --card: #FFFFFF;
  --warm: #FFF8F4;
  --soft: #E4F2EE;
  --border: #DCE7E2;
  --text: #18302B;
  --muted: #52665F;
  --light: #7E928B;
  --primary: #176B5B;
  --primary-deep: #0F5446;
  --primary-soft: #E4F2EE;
  --coral: #B94A32;
  --coral-soft: #FCEAE4;
  --accent: #B94A32;
  --accent-soft: #FCEAE4;
  --ai: #5D4BC3;
  --ai-soft: #ECE9FA;
  --success: #2E7D32;
  --success-soft: #E3F0E5;
  --warning: #B25E09;
  --warning-soft: #F8EDDA;
  --danger: #B42318;
  --danger-soft: #FAE7E5;
  --teal: #176B5B;
  --teal-soft: #E4F2EE;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
}

view, text, input, textarea, picker, button { box-sizing: border-box; }
button { margin: 0; }
button::after { border: 0; }

/* ===== 页面与卡片 ===== */
.page { min-height: 100vh; padding: 24rpx 28rpx 56rpx; }
.page.with-safe-bottom { padding-bottom: calc(56rpx + env(safe-area-inset-bottom)); }
.card { background: var(--card); border: 1rpx solid var(--border); border-radius: 24rpx; padding: 28rpx; box-shadow: 0 4rpx 16rpx rgba(24,48,43,.04); }
.card + .card { margin-top: 20rpx; }

/* ===== Hero（深青绿主品牌 / 珊瑚温情 / 危险） ===== */
.hero { color: #fff; padding: 34rpx 30rpx; border-radius: 28rpx; background: linear-gradient(135deg,#1F8F79,#176B5B 55%,#0F5446); box-shadow: 0 12rpx 28rpx rgba(23,107,91,.20); }
.hero.teal { background: linear-gradient(135deg,#1F8F79,#176B5B); }
.hero.rose { background: linear-gradient(135deg,#C05339,#A93A24); }
.hero.ai { background: linear-gradient(135deg,#6F5BD8,#5D4BC3); }
.hero-title { display: block; font-size: 42rpx; font-weight: 700; line-height: 1.3; }
.hero-subtitle { display: block; margin-top: 10rpx; font-size: 26rpx; opacity: .92; }
.page-title { display: block; font-size: 40rpx; font-weight: 700; }
.page-subtitle { display: block; color: var(--muted); font-size: 26rpx; margin-top: 8rpx; }
.section { margin-top: 32rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.section-title { font-size: 33rpx; font-weight: 650; padding-left: 16rpx; border-left: 8rpx solid var(--primary); }
.section-link { min-height: 64rpx; display: inline-flex; align-items: center; color: var(--primary); font-size: 26rpx; font-weight: 600; }
.muted { color: var(--muted); }
.light { color: var(--light); }
.danger-text { color: var(--danger); }
.success-text { color: var(--success); }
.row { display: flex; align-items: center; }
.between { justify-content: space-between; }
.wrap { flex-wrap: wrap; }
.gap { gap: 14rpx; }
.flex-1 { flex: 1; min-width: 0; }

/* ===== 数据指标 ===== */
.metrics { display: grid; grid-template-columns: repeat(2,1fr); gap: 16rpx; }
.metric { padding: 22rpx; background: var(--card); border: 1rpx solid var(--border); border-radius: 20rpx; }
.metric-number { display: block; font-size: 44rpx; line-height: 1.1; font-weight: 700; }
.metric-label { display: block; margin-top: 6rpx; color: var(--muted); font-size: 26rpx; }
.hero-metrics { display: grid; grid-template-columns: repeat(4,1fr); gap: 8rpx; margin-top: 28rpx; }
.hero-metric { text-align: center; padding: 14rpx 4rpx; background: rgba(255,255,255,.16); border-radius: 16rpx; }
.hero-metric-number { display: block; font-size: 36rpx; font-weight: 700; }
.hero-metric-label { display: block; font-size: 26rpx; opacity: .92; }

/* ===== 列表 ===== */
.list-card { background: var(--card); border: 1rpx solid var(--border); border-radius: 22rpx; padding: 26rpx; margin-bottom: 18rpx; }
.list-title { display: block; font-size: 31rpx; font-weight: 650; line-height: 1.4; }
.list-subtitle { display: block; color: var(--muted); font-size: 26rpx; margin-top: 6rpx; line-height: 1.45; }
.list-meta { display: block; color: var(--light); font-size: 26rpx; margin-top: 8rpx; }
.list-meta { color: var(--light); font-size: 26rpx; margin-top: 10rpx; }
.avatar { width: 88rpx; height: 88rpx; border-radius: 50%; overflow: hidden; background: var(--soft); flex: none; }
.avatar image { width: 100%; height: 100%; display: block; }
.tag { display: inline-flex; align-items: center; min-height: 40rpx; padding: 4rpx 16rpx; border-radius: 999rpx; color: var(--muted); background: var(--soft); font-size: 26rpx; }
.tag.primary { color: var(--primary); background: var(--primary-soft); }
.tag.success { color: var(--success); background: var(--success-soft); }
.tag.warning { color: var(--warning); background: var(--warning-soft); }
.tag.danger { color: var(--danger); background: var(--danger-soft); }
.tag.teal { color: var(--teal); background: var(--teal-soft); }
.tag.ai { color: var(--ai); background: var(--ai-soft); }

/* ===== 按钮：常规热区 ≥ 88rpx ===== */
.actions { display: flex; gap: 14rpx; margin-top: 20rpx; flex-wrap: wrap; }
.btn { min-height: 88rpx; padding: 0 30rpx; display: inline-flex; align-items: center; justify-content: center; border-radius: 18rpx; background: var(--soft); color: var(--text); font-size: 28rpx; font-weight: 600; line-height: 1; transition: opacity .18s ease, transform .18s ease; }
.btn.primary { color: #fff; background: linear-gradient(135deg,#1F8F79,#176B5B); }
.btn.coral { color: #fff; background: var(--coral); }
.btn.teal { color: #fff; background: var(--teal); }
.btn.ai { color: #fff; background: var(--ai); }
.btn.danger { color: var(--danger); background: var(--danger-soft); }
.btn.success { color: #fff; background: var(--success); }
.btn.outline { color: var(--primary); background: #fff; border: 2rpx solid var(--primary); }
.btn.small { min-height: 88rpx; padding: 0 24rpx; font-size: 26rpx; }
.btn.block { width: 100%; }
.btn[disabled] { opacity: .5; }

/* 自定义可点击元素的按压反馈 */
.pressable { transition: opacity .18s ease, transform .18s ease; }
.pressable-hover { opacity: .82; transform: scale(.985); }

/* ===== 筛选与搜索 ===== */
.filter-bar { display: flex; gap: 14rpx; margin: 20rpx 0; flex-wrap: wrap; }
.filter { min-height: 88rpx; padding: 0 24rpx; display: flex; align-items: center; background: var(--card); border: 1rpx solid var(--border); border-radius: 18rpx; color: var(--text); font-size: 26rpx; }
.search { height: 88rpx; padding: 0 24rpx; background: var(--card); border: 1rpx solid var(--border); border-radius: 18rpx; font-size: 28rpx; }

/* ===== 表单 ===== */
.form-card { margin-top: 20rpx; }
.field { margin-bottom: 26rpx; }
.field-label { display: block; font-weight: 600; font-size: 28rpx; margin-bottom: 12rpx; }
.field-hint { display: block; margin-top: 10rpx; color: var(--muted); font-size: 26rpx; line-height: 1.5; }
.required::before { content: '*'; color: var(--danger); margin-right: 6rpx; }
.input, .picker, .textarea { width: 100%; background: #FBFDFC; border: 1rpx solid var(--border); border-radius: 16rpx; padding: 20rpx 22rpx; font-size: 28rpx; color: var(--text); }
.input, .picker { min-height: 88rpx; }
.textarea { min-height: 160rpx; }
.radio-row { display: flex; gap: 14rpx; flex-wrap: wrap; }
.choice { min-height: 88rpx; display: inline-flex; align-items: center; padding: 14rpx 28rpx; background: var(--card); border: 2rpx solid var(--border); border-radius: 16rpx; color: var(--text); font-size: 28rpx; transition: opacity .12s ease; }
.choice.active { color: var(--primary); border-color: var(--primary); background: var(--primary-soft); font-weight: 600; }
.form-actions { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 16rpx; margin-top: 32rpx; }
.form-actions > .btn { width: 100%; min-width: 0; padding-left: 12rpx; padding-right: 12rpx; }

/* ===== 空 / 加载 / 提示 ===== */
.empty { padding: 72rpx 32rpx; text-align: center; color: var(--muted); font-size: 28rpx; }
.empty-icon { display: block; width: 128rpx; height: 128rpx; margin: 0 auto 18rpx; }
.empty-icon-emoji { display: block; font-size: 72rpx; margin-bottom: 12rpx; }
.loading { padding: 56rpx; text-align: center; color: var(--muted); font-size: 28rpx; }
.notice { padding: 22rpx 26rpx; color: var(--text); background: var(--warning-soft); border: 1rpx solid #EBD9BC; border-radius: 18rpx; font-size: 26rpx; line-height: 1.6; }
.notice.safe { color: var(--primary-deep); background: var(--primary-soft); border-color: #C4DED6; }
.divider { height: 1rpx; background: var(--border); margin: 24rpx 0; }
.safe-bottom { height: env(safe-area-inset-bottom); }
