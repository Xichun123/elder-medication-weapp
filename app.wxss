page {
  --bg: #faf5ef;
  --card: #ffffff;
  --soft: #f3ebe0;
  --border: #ece1d1;
  --text: #3d2e1f;
  --muted: #7a6648;
  --light: #b09a7c;
  --primary: #e87a5d;
  --primary-deep: #d9684a;
  --primary-soft: #fce8e0;
  --success: #5fa074;
  --success-soft: #e1efe5;
  --warning: #d4a04c;
  --warning-soft: #fbf2e0;
  --danger: #c75450;
  --danger-soft: #fbe5e3;
  --teal: #5ba89a;
  --teal-soft: #e0efec;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
}

view, text, input, textarea, picker, button { box-sizing: border-box; }
button { margin: 0; }
button::after { border: 0; }

.page { min-height: 100vh; padding: 24rpx 24rpx 56rpx; }
.page.with-safe-bottom { padding-bottom: calc(56rpx + env(safe-area-inset-bottom)); }
.card { background: var(--card); border: 1rpx solid var(--border); border-radius: 24rpx; padding: 28rpx; box-shadow: 0 6rpx 18rpx rgba(61,46,31,.05); }
.card + .card { margin-top: 20rpx; }
.hero { color: #fff; padding: 34rpx 30rpx; border-radius: 28rpx; background: linear-gradient(135deg,#f0916f,#e87a5d 55%,#d9684a); box-shadow: 0 14rpx 30rpx rgba(232,122,93,.22); }
.hero.teal { background: linear-gradient(135deg,#6fbbac,#5ba89a); }
.hero.rose { background: linear-gradient(135deg,#e58585,#c75450); }
.hero-title { display: block; font-size: 42rpx; font-weight: 700; line-height: 1.3; }
.hero-subtitle { display: block; margin-top: 10rpx; font-size: 25rpx; opacity: .9; }
.page-title { display: block; font-size: 38rpx; font-weight: 700; }
.page-subtitle { display: block; color: var(--muted); font-size: 24rpx; margin-top: 6rpx; }
.section { margin-top: 30rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.section-title { font-size: 32rpx; font-weight: 650; padding-left: 14rpx; border-left: 8rpx solid var(--primary); }
.section-link { color: var(--primary); font-size: 25rpx; }
.muted { color: var(--muted); }
.light { color: var(--light); }
.danger-text { color: var(--danger); }
.success-text { color: var(--success); }
.row { display: flex; align-items: center; }
.between { justify-content: space-between; }
.wrap { flex-wrap: wrap; }
.gap { gap: 14rpx; }
.flex-1 { flex: 1; min-width: 0; }

.metrics { display: grid; grid-template-columns: repeat(2,1fr); gap: 16rpx; }
.metric { padding: 22rpx; background: var(--card); border: 1rpx solid var(--border); border-radius: 20rpx; }
.metric-number { display: block; font-size: 44rpx; line-height: 1.1; font-weight: 700; }
.metric-label { display: block; margin-top: 6rpx; color: var(--muted); font-size: 23rpx; }
.hero-metrics { display: grid; grid-template-columns: repeat(4,1fr); gap: 8rpx; margin-top: 28rpx; }
.hero-metric { text-align: center; padding: 12rpx 4rpx; background: rgba(255,255,255,.14); border-radius: 16rpx; }
.hero-metric-number { display: block; font-size: 35rpx; font-weight: 700; }
.hero-metric-label { display: block; font-size: 20rpx; opacity: .9; }

.list-card { background: var(--card); border: 1rpx solid var(--border); border-radius: 22rpx; padding: 24rpx; margin-bottom: 18rpx; }
.list-title { font-size: 31rpx; font-weight: 650; }
.list-subtitle { color: var(--muted); font-size: 24rpx; margin-top: 4rpx; }
.list-meta { color: var(--light); font-size: 22rpx; margin-top: 10rpx; }
.avatar { width: 84rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: var(--soft); font-size: 48rpx; flex: none; }
.tag { display: inline-flex; padding: 4rpx 14rpx; border-radius: 999rpx; color: var(--muted); background: var(--soft); font-size: 21rpx; }
.tag.primary { color: var(--primary); background: var(--primary-soft); }
.tag.success { color: var(--success); background: var(--success-soft); }
.tag.warning { color: var(--warning); background: var(--warning-soft); }
.tag.danger { color: var(--danger); background: var(--danger-soft); }
.tag.teal { color: var(--teal); background: var(--teal-soft); }
.actions { display: flex; gap: 12rpx; margin-top: 20rpx; flex-wrap: wrap; }
.btn { min-height: 72rpx; padding: 0 26rpx; display: inline-flex; align-items: center; justify-content: center; border-radius: 16rpx; background: var(--soft); color: var(--text); font-size: 26rpx; line-height: 1; }
.btn.primary { color: #fff; background: linear-gradient(135deg,#f0916f,#e87a5d); }
.btn.teal { color: #fff; background: var(--teal); }
.btn.danger { color: var(--danger); background: var(--danger-soft); }
.btn.success { color: #fff; background: var(--success); }
.btn.small { min-height: 58rpx; padding: 0 20rpx; font-size: 23rpx; }
.btn.block { width: 100%; }
.btn[disabled] { opacity: .5; }

.filter-bar { display: flex; gap: 14rpx; margin: 20rpx 0; flex-wrap: wrap; }
.filter { min-height: 68rpx; padding: 0 20rpx; display: flex; align-items: center; background: var(--card); border: 1rpx solid var(--border); border-radius: 16rpx; color: var(--muted); font-size: 25rpx; }
.search { height: 72rpx; padding: 0 22rpx; background: var(--card); border: 1rpx solid var(--border); border-radius: 16rpx; font-size: 26rpx; }

.form-card { margin-top: 20rpx; }
.field { margin-bottom: 24rpx; }
.field-label { display: block; font-weight: 600; margin-bottom: 10rpx; }
.required::before { content: '*'; color: var(--danger); margin-right: 6rpx; }
.input, .picker, .textarea { width: 100%; background: #fdfaf6; border: 1rpx solid var(--border); border-radius: 14rpx; padding: 18rpx 20rpx; font-size: 27rpx; color: var(--text); }
.input, .picker { min-height: 76rpx; }
.textarea { min-height: 150rpx; }
.radio-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.choice { padding: 14rpx 22rpx; background: var(--soft); border: 2rpx solid transparent; border-radius: 14rpx; font-size: 25rpx; }
.choice.active { color: var(--primary); border-color: var(--primary); background: var(--primary-soft); }
.form-actions { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 16rpx; margin-top: 30rpx; }
.form-actions > .btn { width: 100%; min-width: 0; padding-left: 12rpx; padding-right: 12rpx; }

.empty { padding: 70rpx 30rpx; text-align: center; color: var(--muted); }
.empty-icon { display: block; font-size: 70rpx; margin-bottom: 10rpx; }
.loading { padding: 50rpx; text-align: center; color: var(--muted); }
.notice { padding: 20rpx 24rpx; color: var(--muted); background: var(--warning-soft); border-radius: 16rpx; font-size: 24rpx; }
.divider { height: 1rpx; background: var(--border); margin: 22rpx 0; }
.safe-bottom { height: env(safe-area-inset-bottom); }
