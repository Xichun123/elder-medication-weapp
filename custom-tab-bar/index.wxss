.tabbar {
  position: relative;
  display: flex;
  align-items: flex-end;
  height: calc(120rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  box-shadow: 0 -6rpx 24rpx rgba(46, 92, 66, 0.08);
  border-radius: 32rpx 32rpx 0 0;
}

.tabbar-item {
  flex: 1;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tabbar-icon-wrap { position: relative; width: 52rpx; height: 52rpx; }
.tabbar-icon { width: 52rpx; height: 52rpx; display: block; }

.tabbar-badge {
  position: absolute;
  top: -10rpx;
  right: -22rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #D9503F;
  color: #fff;
  font-size: 21rpx;
  line-height: 1;
}

.tabbar-label { font-size: 22rpx; color: #97A69C; line-height: 1.2; }
.tabbar-item.active .tabbar-label { color: #3EAE5B; font-weight: 600; }

/* 中央凸起 + 按钮 */
.tabbar-item.center { justify-content: flex-end; padding-bottom: 10rpx; }
.tabbar-plus {
  position: relative;
  top: -34rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CBF6C, #3EAE5B);
  box-shadow: 0 10rpx 24rpx rgba(62, 174, 91, 0.4);
  border: 8rpx solid #ffffff;
}
.tabbar-plus-icon { color: #fff; font-size: 60rpx; font-weight: 400; line-height: 1; margin-top: -6rpx; }
.tabbar-item.center .tabbar-label { position: relative; top: -26rpx; }
